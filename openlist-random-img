<script src="https://polyfill.alicdn.com/v3/polyfill.min.js?features=String.prototype.replaceAll"></script>

<style>
:root {
  --ol-rand-bg: none;
}

/* 关闭默认通知 X */
.notify-render .hope-close-button {
  display: none;
}

/* 背景层：独立 fixed，不跟内容层滚动 */
#ol-bg-layer {
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  background-image: var(--ol-rand-bg);
  background-repeat: no-repeat;
  background-size: cover;
  background-position: center;
  background-color: #0b0b0b; /* 随机图没加载时纯色兜底 */
}

/* 内容层抬到背景之上 */
#root,
.App {
  position: relative;
}

/* 清掉大容器背景，避免底部黑块 */
html,
body,
#root,
.App,
.hope-ui-light,
.hope-ui-dark {
  background: transparent !important;
}

/* 头部渐变 */
#root > .header {
  background: linear-gradient(180deg, rgba(255,255,255,0.30), rgba(255,255,255,0));
}

/* 底部渐变条 */
.footerd {
  width: 100vw;
  height: 5vh;
  position: fixed;
  bottom: 0;
  left: 0;
  z-index: 2;
  pointer-events: none;
  background: linear-gradient(0deg, rgba(255,255,255,0.30), rgba(255,255,255,0));
}

/* 面板玻璃化（稳定选择器） */
.hope-ui-light .obj-box,
.hope-ui-light .body > .nav,
.hope-ui-light .hope-icon-button,
.hope-ui-light pre {
  backdrop-filter: blur(1px);
  background-color: rgba(255,255,255,0.65) !important;
}

.hope-ui-dark .obj-box,
.hope-ui-dark .body > .nav,
.hope-ui-dark .hope-icon-button,
.hope-ui-dark pre {
  backdrop-filter: blur(1px);
  background-color: rgb(0 0 0 / 50%) !important;
}

.body > .nav {
  border-radius: var(--hope-radii-xl);
}
.body > .nav::after {
  display: none;
}

.table {
  margin: auto;
}

.hope-image {
  filter: drop-shadow(2px 4px 8px rgb(255,255,255));
}

/* 日夜按钮 */
button#hope-menu-daynight-switch-trigger {
  position: fixed;
  bottom: 7.5vh;
  left: 2.5vw;
  z-index: 114;
  width: 40px;
  height: 40px;
  border: 0;
  border-radius: 9999px;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}
</style>

<!-- 创建固定背景层 + 底部渐变 -->
<script>
(function () {
  function ensureBgLayer() {
    if (!document.getElementById("ol-bg-layer")) {
      var bg = document.createElement("div");
      bg.id = "ol-bg-layer";
      document.body.insertBefore(bg, document.body.firstChild);
    }
  }

  function ensureFooter() {
    if (!document.querySelector(".footerd")) {
      var el = document.createElement("div");
      el.className = "footerd";
      document.body.appendChild(el);
    }
  }

  function boot() {
    ensureBgLayer();
    ensureFooter();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }
})();
</script>

<!-- 随机背景（用 rapi random-img-only.js，不走 /random/h 路由）-->
<script>
(function () {
  var RANDOM_SCRIPT = "https://rapi.kyr.us.ci/random-img-only.js";
  var RANDOM_SCRIPT_ID = "ol-random-img-only-script";

  function pickRandomUrl() {
    var portrait = window.matchMedia("(max-aspect-ratio: 1/1)").matches;
    if (portrait && typeof window.getRandomPicV === "function") return window.getRandomPicV();
    if (!portrait && typeof window.getRandomPicH === "function") return window.getRandomPicH();
    if (typeof window.getRandomPicH === "function") return window.getRandomPicH();
    if (typeof window.getRandomPicV === "function") return window.getRandomPicV();
    return "";
  }

  function applyRandomBg() {
    var url = pickRandomUrl();
    if (!url) return;

    var img = new Image();
    img.onload = function () {
      document.documentElement.style.setProperty("--ol-rand-bg", 'url("' + url + '")');
    };
    img.onerror = function () {
      console.warn("[openlist-header] random bg load failed:", url);
    };
    img.src = url;
  }

  function waitReadyThenApply() {
    if (window.__randomPicApiReady || typeof window.getRandomPicH === "function" || typeof window.getRandomPicV === "function") {
      applyRandomBg();
      return;
    }

    window.addEventListener("random-pic-api:ready", function () {
      applyRandomBg();
    }, { once: true });

    setTimeout(applyRandomBg, 1200);
  }

  function loadRandomRuntime() {
    if (document.getElementById(RANDOM_SCRIPT_ID)) {
      waitReadyThenApply();
      return;
    }

    var s = document.createElement("script");
    s.id = RANDOM_SCRIPT_ID;
    s.src = RANDOM_SCRIPT;
    s.async = true;
    s.onload = waitReadyThenApply;
    s.onerror = function () {
      console.warn("[openlist-header] failed to load random-img-only.js");
    };
    document.head.appendChild(s);
  }

  function boot() {
    loadRandomRuntime();

    var mql = window.matchMedia("(max-aspect-ratio: 1/1)");
    if (mql && mql.addEventListener) {
      mql.addEventListener("change", function () {
        applyRandomBg();
      });
    } else if (mql && mql.addListener) {
      mql.addListener(function () {
        applyRandomBg();
      });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }
})();
</script>

<!-- 日夜主题切换 -->
<script>
(function () {
  var STORAGE_KEY = "openlist-theme";

  function unlockScroll() {
    var docEl = document.documentElement;
    var body = document.body;
    if (docEl) {
      docEl.style.overflow = "";
      docEl.style.overflowY = "";
      docEl.style.position = "";
      docEl.style.width = "";
    }
    if (body) {
      body.style.overflow = "";
      body.style.overflowY = "";
      body.style.position = "";
      body.style.width = "";
      body.style.paddingRight = "";
      body.style.touchAction = "";
    }
  }

  function hasVisibleLayer(selector) {
    var nodes = document.querySelectorAll(selector);
    for (var i = 0; i < nodes.length; i++) {
      var s = window.getComputedStyle(nodes[i]);
      var rect = nodes[i].getBoundingClientRect();
      var visible = s.display !== "none" && s.visibility !== "hidden" && s.opacity !== "0" && rect.width > 0 && rect.height > 0;
      if (visible) return true;
    }
    return false;
  }

  function clearStuckOverlays() {
    var hasVisibleDrawer = hasVisibleLayer(".hope-drawer__content-container");
    var hasVisibleModal = hasVisibleLayer(".hope-modal__content, .hope-modal__content-container");
    if (hasVisibleDrawer || hasVisibleModal) return;

    var overlays = document.querySelectorAll(".hope-drawer__overlay, .hope-modal__overlay");
    for (var i = 0; i < overlays.length; i++) {
      overlays[i].style.pointerEvents = "none";
    }
  }

  function cleanupThemeSwitchUi() {
    // Only reset scroll lock; do not hide Drawer/Modal nodes globally.
    // Hiding these nodes can break OpenList side panel interactions.
    unlockScroll();
    clearStuckOverlays();
    setTimeout(unlockScroll, 120);
    setTimeout(clearStuckOverlays, 120);
    setTimeout(unlockScroll, 320);
    setTimeout(clearStuckOverlays, 320);
  }

  function getThemeTargets() {
    return document.querySelectorAll(".hope-ui-light, .hope-ui-dark");
  }

  function detectTheme() {
    var targets = getThemeTargets();
    for (var i = 0; i < targets.length; i++) {
      if (targets[i].classList.contains("hope-ui-dark")) return "dark";
    }
    return "light";
  }

  function applyTheme(theme) {
    var dark = theme === "dark";
    var targets = getThemeTargets();

    for (var i = 0; i < targets.length; i++) {
      targets[i].classList.remove("hope-ui-light", "hope-ui-dark");
      targets[i].classList.add(dark ? "hope-ui-dark" : "hope-ui-light");
    }

    try {
      localStorage.setItem(STORAGE_KEY, dark ? "dark" : "light");
    } catch (_e) {}

    cleanupThemeSwitchUi();
  }

  function toggleTheme(e) {
    if (e) {
      if (e.preventDefault) e.preventDefault();
      if (e.stopPropagation) e.stopPropagation();
      if (e.stopImmediatePropagation) e.stopImmediatePropagation();
    }

    var next = detectTheme() === "light" ? "dark" : "light";
    applyTheme(next);
  }

  function ensureSwitchButton() {
    var btn = document.getElementById("hope-menu-daynight-switch-trigger");

    if (!btn) {
      btn = document.createElement("button");
      btn.id = "hope-menu-daynight-switch-trigger";
      btn.type = "button";
      btn.setAttribute("aria-label", "switch layout");
      btn.className = "hope-icon-button";
      btn.innerHTML =
        '<svg viewBox="0 0 1024 1024" width="1em" height="1em" aria-hidden="true">' +
        '<path d="M512 0c282.7776 0 512 229.2224 512 512s-229.2224 512-512 512S0 794.7776 0 512 229.2224 0 512 0z m0 51.2a460.8 460.8 0 0 0-13.568 921.3952L512 972.8v-256a204.8 204.8 0 1 0 0-409.6V51.2z m0 256v409.6a204.8 204.8 0 1 1 0-409.6z" fill="currentColor"></path>' +
        "</svg>";
      document.body.appendChild(btn);
    }

    if (!btn.dataset.bound) {
      btn.dataset.bound = "1";
      btn.addEventListener("click", toggleTheme, true);
    }
  }

  function restoreTheme() {
    var saved = null;
    try { saved = localStorage.getItem(STORAGE_KEY); } catch (_e) {}
    if (saved === "light" || saved === "dark") {
      applyTheme(saved);
    }
  }

  function boot() {
    restoreTheme();
    ensureSwitchButton();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }
})();
</script>

