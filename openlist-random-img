<script src="https://polyfill.alicdn.com/v3/polyfill.min.js?features=String.prototype.replaceAll"></script>

<style>
:root {
  --ol-rand-bg: none;
}

.notify-render .hope-close-button {
  display: none;
}

/* 背景：light/dark 共用同一张随机图 */
.hope-ui-light,
.hope-ui-dark {
  background-image: var(--ol-rand-bg) !important;
  background-repeat: no-repeat;
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  background-color: #0b0b0b; /* 网络慢时纯色，不用静态图 */
}

@media (max-aspect-ratio: 1/1) {
  .hope-ui-light,
  .hope-ui-dark {
    background-attachment: scroll;
  }
}

#root > .header {
  background: linear-gradient(180deg, rgba(255,255,255,0.3), rgba(255,255,255,0));
}

.footerd {
  width: 100vw;
  height: 5vh;
  position: fixed;
  bottom: 0;
  left: 0;
  pointer-events: none;
  background: linear-gradient(0deg, rgba(255,255,255,0.3), rgba(255,255,255,0));
}

.App {
  min-height: 85vh;
}

.table {
  margin: auto;
}

#canvas-basic {
  position: fixed;
  display: block;
  width: 100%;
  height: 100%;
  inset: 0;
  z-index: -999;
}

.hope-image {
  filter: drop-shadow(2px 4px 8px rgb(255,255,255));
}

button#hope-menu-daynight-switch-trigger {
  position: fixed;
  bottom: 7.5vh;
  left: 2.5vw;
  z-index: 114;
  width: 40px;
  height: 40px;
  border: 0;
  border-radius: 9999px;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

/* 更稳的兜底面板色（避免 hash 类名变化） */
.hope-ui-light .obj-box,
.hope-ui-light .body > .nav,
.hope-ui-light .hope-icon-button,
.hope-ui-light pre {
  backdrop-filter: blur(1px);
  background-color: rgba(255,255,255,0.65) !important;
}

.hope-ui-dark .obj-box,
.hope-ui-dark .body > .nav,
.hope-ui-dark .hope-icon-button,
.hope-ui-dark pre {
  backdrop-filter: blur(1px);
  background-color: rgb(0 0 0 / 50%) !important;
}

.body > .nav {
  border-radius: var(--hope-radii-xl);
}

.body > .nav::after {
  display: none;
}
</style>

<!-- 底部渐变条 -->
<script>
(function () {
  function ensureFooter() {
    if (!document.querySelector(".footerd")) {
      var el = document.createElement("div");
      el.className = "footerd";
      document.body.appendChild(el);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", ensureFooter, { once: true });
  } else {
    ensureFooter();
  }
})();
</script>

<!-- 随机背景：使用 random-img-only.js 提供的 getRandomPicH/V -->
<script>
(function () {
  var RANDOM_SCRIPT = "https://rapi.kyr.us.ci/random-img-only.js";
  var SCRIPT_ID = "ol-random-img-only-script";

  function pickUrl() {
    var portrait = window.matchMedia("(max-aspect-ratio: 1/1)").matches;
    if (portrait && typeof window.getRandomPicV === "function") return window.getRandomPicV();
    if (!portrait && typeof window.getRandomPicH === "function") return window.getRandomPicH();
    if (typeof window.getRandomPicH === "function") return window.getRandomPicH();
    if (typeof window.getRandomPicV === "function") return window.getRandomPicV();
    return "";
  }

  function applyRandomBgOnce() {
    var url = pickUrl();
    if (!url) return;

    var img = new Image();
    img.onload = function () {
      document.documentElement.style.setProperty("--ol-rand-bg", 'url("' + url + '")');
    };
    img.onerror = function () {
      console.warn("[openlist-header] random bg load failed:", url);
    };
    img.src = url;
  }

  function waitAndApply() {
    if (window.__randomPicApiReady || typeof window.getRandomPicH === "function" || typeof window.getRandomPicV === "function") {
      applyRandomBgOnce();
      return;
    }

    window.addEventListener("random-pic-api:ready", function onReady() {
      applyRandomBgOnce();
    }, { once: true });

    setTimeout(function () {
      applyRandomBgOnce();
    }, 1200);
  }

  function loadRandomScript() {
    if (document.getElementById(SCRIPT_ID)) {
      waitAndApply();
      return;
    }

    var s = document.createElement("script");
    s.id = SCRIPT_ID;
    s.src = RANDOM_SCRIPT;
    s.async = true;
    s.onload = waitAndApply;
    s.onerror = function () {
      console.warn("[openlist-header] failed to load random-img-only.js");
    };
    document.head.appendChild(s);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", loadRandomScript, { once: true });
  } else {
    loadRandomScript();
  }
})();
</script>

<!-- 日夜主题切换按钮 -->
<script>
(function () {
  var STORAGE_KEY = "openlist-theme";

  function unlockScroll() {
    var docEl = document.documentElement;
    var body = document.body;
    if (docEl) {
      docEl.style.overflow = "";
      docEl.style.overflowY = "";
      docEl.style.position = "";
      docEl.style.width = "";
    }
    if (body) {
      body.style.overflow = "";
      body.style.overflowY = "";
      body.style.position = "";
      body.style.width = "";
      body.style.paddingRight = "";
      body.style.touchAction = "";
    }
  }

  function cleanupThemeSwitchUi() {
    var leftovers = document.querySelectorAll(".hope-drawer__overlay, .hope-drawer__content-container, .hope-modal__overlay");
    for (var i = 0; i < leftovers.length; i++) {
      leftovers[i].style.display = "none";
      leftovers[i].style.pointerEvents = "none";
    }
    unlockScroll();
    setTimeout(unlockScroll, 120);
    setTimeout(unlockScroll, 320);
  }

  function getThemeTargets() {
    return document.querySelectorAll(".hope-ui-light, .hope-ui-dark");
  }

  function detectTheme() {
    var targets = getThemeTargets();
    for (var i = 0; i < targets.length; i++) {
      if (targets[i].classList.contains("hope-ui-dark")) return "dark";
    }
    return "light";
  }

  function applyTheme(theme) {
    var toDark = theme === "dark";
    var targets = getThemeTargets();
    for (var i = 0; i < targets.length; i++) {
      targets[i].classList.remove("hope-ui-light", "hope-ui-dark");
      targets[i].classList.add(toDark ? "hope-ui-dark" : "hope-ui-light");
    }
    try { localStorage.setItem(STORAGE_KEY, toDark ? "dark" : "light"); } catch (_e) {}
    cleanupThemeSwitchUi();
  }

  function daynightswitch(e) {
    if (e) {
      if (e.preventDefault) e.preventDefault();
      if (e.stopPropagation) e.stopPropagation();
      if (e.stopImmediatePropagation) e.stopImmediatePropagation();
    }
    var next = detectTheme() === "light" ? "dark" : "light";
    applyTheme(next);
  }

  function ensureSwitchButton() {
    var btn = document.getElementById("hope-menu-daynight-switch-trigger");
    if (!btn) {
      btn = document.createElement("button");
      btn.id = "hope-menu-daynight-switch-trigger";
      btn.type = "button";
      btn.setAttribute("role", "button");
      btn.setAttribute("aria-label", "switch layout");
      btn.className = "hope-icon-button";
      btn.innerHTML =
        '<svg viewBox="0 0 1024 1024" width="1em" height="1em" aria-hidden="true">' +
        '<path d="M512 0c282.7776 0 512 229.2224 512 512s-229.2224 512-512 512S0 794.7776 0 512 229.2224 0 512 0z m0 51.2a460.8 460.8 0 0 0-13.568 921.3952L512 972.8v-256a204.8 204.8 0 1 0 0-409.6V51.2z m0 256v409.6a204.8 204.8 0 1 1 0-409.6z" fill="currentColor"></path>' +
        "</svg>";
      document.body.appendChild(btn);
    }

    if (!btn.dataset.bound) {
      btn.dataset.bound = "1";
      btn.addEventListener("click", daynightswitch, true);
    }
  }

  function restoreTheme() {
    var saved = null;
    try { saved = localStorage.getItem(STORAGE_KEY); } catch (_e) {}
    if (saved === "light" || saved === "dark") {
      applyTheme(saved);
    }
  }

  function boot() {
    restoreTheme();
    ensureSwitchButton();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }
})();
</script>
